# Шаблон конфигурации окружения для TwoComms
# Скопировать в .env и заполнить реальными значениями.
# .env находится в .gitignore — его НИКОГДА не должно быть в git.

# === Django ===
DEBUG=False
SECRET_KEY=replace-with-strong-random-50-char-string
ALLOWED_HOSTS=twocomms.shop,www.twocomms.shop

# === База данных ===
DB_ENGINE=django.db.backends.mysql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306
DB_CONN_MAX_AGE=60

# === Redis (cache + sessions) ===
# Формат: redis://[:password]@host:port/db   или  rediss://... (TLS)
REDIS_URL=
REDIS_KEY_PREFIX=twocomms
CACHE_DEFAULT_TIMEOUT=300
REDIS_SOCKET_TIMEOUT=2.0
REDIS_SOCKET_CONNECT_TIMEOUT=2.0
REDIS_IGNORE_EXCEPTIONS=true

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=

# === Monobank ===
MONOBANK_TOKEN=

# === Email (SMTP) ===
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# === SSH deploy (НЕ хранить в файле — экспортировать в shell) ===
# Никогда не commit'ить пароли. Использовать ssh-key или ENV переменные.
# TWC_SSH_PASS=...      # будет выставлено через `export TWC_SSH_PASS=...`
