msgid "dtf друк, кастомний принт, друк на худі, друк на футболках, кастомний одяг, twocomms, dtf конфігуратор"
msgstr "dtf print, custom print, print on hoodies, print on t-shirts, custom apparel, twocomms, dtf configurator"
