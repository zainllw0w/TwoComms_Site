msgstr "Маршруты"

msgid "Куди перейти далі"
msgstr "Куда перейти дальше"

msgid "В каталог"
msgstr "В каталог"

msgid "Для готових речей, новинок і прямого переходу до покупки."
msgstr "Для готовых вещей, новинок и прямого перехода к покупке."

msgid "На size guide"
msgstr "В size guide"

msgid "Щоб звірити посадку перед оплатою."
msgstr "Чтобы сверить посадку перед оплатой."

msgid "У help-центр"
msgstr "В help-центр"

msgid "Коли потрібні правила, оплата, логістика або післяпродажний сервіс."
