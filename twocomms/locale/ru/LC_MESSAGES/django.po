msgid ""
"TwoComms, харківський бренд одягу, український streetwear бренд, military-"
"adjacent одяг, одяг зі змістом, сенсові принти, дві коми, Харків"
msgstr ""
"TwoComms, харьковский бренд одежды, украинский streetwear бренд, military-"
"adjacent одежда, одежда со смыслом, смысловые принты, две запятые, Харьков"

msgid "Brand"
