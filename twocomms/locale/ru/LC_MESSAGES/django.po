#: storefront/support_content.py:212 twocomms_django_theme/templates/pages/pro_brand.html:6 twocomms_django_theme/templates/pages/pro_brand.html:9
msgid "TwoComms — харківський бренд одягу про характер, стійкість і продовження"
msgstr "TwoComms — харьковский бренд одежды о характере, стойкости и продолжении"

#: storefront/support_content.py:213
msgid "TwoComms — український streetwear / military-adjacent бренд із Харкова. Одяг з кодом, сенсовими принтами, реальним походженням і філософією: не крапка, а продовження."
msgstr "TwoComms — украинский streetwear / military-adjacent бренд из Харькова. Одежда с кодом, смысловыми принтами, настоящим происхождением и философией: не точка, а продолжение."

#: storefront/support_content.py:214
msgid "TwoComms, харківський бренд одягу, український streetwear бренд, military-adjacent одяг, одяг зі змістом, сенсові принти, дві коми, Харків"
msgstr "TwoComms, харьковский бренд одежды, украинский streetwear бренд, military-adjacent одежда, одежда со смыслом, смысловые принты, две запятые, Харьков"

#: storefront/support_content.py:215
msgid "Brand"
msgstr "Brand"

#: storefront/support_content.py:216 twocomms_django_theme/templates/pages/pro_brand.html:14
msgid "TwoComms — не крапка. Продовження."
msgstr "TwoComms — не точка. Продолжение."

#: storefront/support_content.py:217
msgid "TwoComms — харківський streetwear / military-adjacent бренд про характер, сенсові принти, внутрішню дисципліну і рух далі після критичної точки."
msgstr "TwoComms — харьковский streetwear / military-adjacent бренд про характер, смысловые принты, внутреннюю дисциплину и движение дальше после критической точки."

