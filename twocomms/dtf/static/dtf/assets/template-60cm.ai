<svg width="60cm" height="100cm" viewBox="0 0 600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
      <path d="M 10 0 L 0 0 0 10" fill="none" stroke="gray" stroke-width="0.5"/>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="white"/>
  <rect width="100%" height="100%" fill="url(#grid)" opacity="0.2"/>
  
  <!-- Safe Area (1cm margin) -->
  <rect x="10" y="10" width="580" height="980" fill="none" stroke="#FF4500" stroke-width="2" stroke-dasharray="10,5"/>
  <text x="300" y="50" font-family="Arial" font-size="20" text-anchor="middle" fill="#333">DTF 60cm Roll Template</text>
  <text x="300" y="80" font-family="Arial" font-size="14" text-anchor="middle" fill="#666">Safe Print Area (58cm width)</text>
  
  <line x1="10" y1="0" x2="10" y2="1000" stroke="red" stroke-width="1"/>
  <line x1="590" y1="0" x2="590" y2="1000" stroke="red" stroke-width="1"/>
</svg>
